# PROD OR DEV
ENV=PROD

#CONF_NAME

# Allow http request's to backend
ALLOW_HTTP=false

# Default Authetik url
AUTHORIZATION_URL=https://auth.example.com/application/o/authorize/

# Authentik Client ID
AUTHENTIK_CLIENT_ID=

# Desktop app OAuth settings
APP_OAUTH_CLIENT_ID=
APP_OAUTH_AUTHORIZATION_URL=https://auth.example.com/application/o/authorize/
APP_OAUTH_TOKEN_URL=https://auth.example.com/application/o/token/
APP_OAUTH_USER_ID=desktop-user
APP_OAUTH_STORE_DIR=~/.project-app/oauth-store